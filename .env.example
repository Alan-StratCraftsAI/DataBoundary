# Optional legacy path: copy to `.env` or `.env.local` only if you do not
# want to use `config.local.json`. The repo now prefers `config.local.json`.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=

# Optional: multiple Gemini keys for rate-limit rotation.
# GOOGLE_API_KEY_2=
# GOOGLE_API_KEY_3=

# Optional: point DataBoundary at a different local JSON config file.
# DATABOUNDARY_CONFIG=/absolute/path/to/config.local.json
